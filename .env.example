# Copy this file to .env and fill in your own values.
# Never commit your real .env file — it's already excluded via .gitignore.

# Formspree endpoint for the contact form (default option).
# Sign up at https://formspree.io, create a form, and paste its endpoint here.
# Example: https://formspree.io/f/abcd1234
VITE_FORM_ENDPOINT=

# See README.md for setup instructions and alternatives
# (Web3Forms, EmailJS) if you'd prefer a different form service.
